# ─────────────────────────────────────────────
# BrainBattle Backend — Environment Config
# ─────────────────────────────────────────────

# Flask settings
FLASK_DEBUG=true
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Secret key (change this in production!)
SECRET_KEY=brainbattle-super-secret-key-change-me

# Database (defaults to local SQLite — change to PostgreSQL URL for production)
# DATABASE_URL=sqlite:///database/db.sqlite3
# DATABASE_URL=postgresql://user:password@host/dbname

# CORS — which origins are allowed to call the API
# Use * to allow all (development), or set specific origins for production:
# CORS_ORIGINS=https://yourwebsite.com,http://localhost:5173
CORS_ORIGINS=*
